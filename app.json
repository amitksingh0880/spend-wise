{
  "expo": {
    "name": "spend-wise",
    "slug": "spend-wise",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-square.png",
    "scheme": "spendwise",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f766e",
        "foregroundImage": "./assets/images/app-icon-adaptive-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "READ_SMS",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS"
      ],
      "package": "com.amit.k.singh.spendwise"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f766e",
          "dark": {
            "backgroundColor": "#115e59"
          }
        }
      ],
      "expo-web-browser",
      "expo-background-fetch",
      "expo-task-manager",
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2c86979e-8546-4b9b-9c89-2097071a2875"
      }
    }
  }
}
